    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_tender-contracting ;
    du:requiresAction du:verb_verify .

du:U_T74 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T36 ;
    skos:definition "A mitigation instance that reduces uncertainty by systematically verifying that design outputs comply with agreed requirements, specifications, and regulatory frameworks before tendering or execution, preventing deviations and late compliance-related surprises."@en ;
    skos:prefLabel "Compliance Checking"@en ;
