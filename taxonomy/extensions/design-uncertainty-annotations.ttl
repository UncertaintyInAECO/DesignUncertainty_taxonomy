    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_verify .

du:U_T75 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T36 ;
    skos:definition "A mitigation instance that reduces uncertainty by verifying actual spatial or operational performance in use and adjusting assumptions or requirements accordingly."@en ;
    skos:prefLabel "Performance-in-Use Validation"@en ;
