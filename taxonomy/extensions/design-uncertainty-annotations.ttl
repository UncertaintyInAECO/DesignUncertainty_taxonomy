du:U_T58 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T33 ;
    skos:definition "A mitigation instance that reduces performance uncertainty by anticipating degradation, operational demands, failure risk, and lifecycle impacts, embedding maintenance logic, energy strategy, and durability considerations into long-term planning."@en ;
