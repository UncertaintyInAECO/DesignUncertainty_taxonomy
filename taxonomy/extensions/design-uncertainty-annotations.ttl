    du:requiresAction du:verb_plan .

du:U_T60 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T33 ;
    skos:definition "A mitigation instance that reduces uncertainty by detailed technical resolution, ensuring robustness, and completeness of design solutions."@en ;
    skos:prefLabel "Technical Exhaustivenes"@en ;
