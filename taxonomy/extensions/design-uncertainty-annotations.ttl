    du:performedByStakeholder du:stakeholder_contractors ;
    du:performedInPhase du:phase_construction-execution ;
    du:requiresAction du:verb_plan .

du:U_T65 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T34 ;
    skos:definition "A mitigation instance that reduces uncertainty by limiting experimentation in technical and constructive choices, relying on consolidated solutions and selectively allowing innovation only within controlled boundaries."@en ;
    skos:prefLabel "Relying on well established methods"@en ;
    du:addressesObject_m du:object_design-solution-technical-definition ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_standardize .

du:U_T66 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T34 ;
    skos:definition "A mitigation instance that reduces uncertainty by structuring documentation, workflows, and organizational processes into replicable, predictable, and transparent frameworks that guide project development over time."@en ;
    skos:prefLabel "Process Standardization"@en ;
