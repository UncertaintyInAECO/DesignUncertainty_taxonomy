        du:Object ;
    skos:prefLabel "Contracts & Procurement"@en .

du:object_team-coordination-roles a skos:Concept,
        du:Object ;
    skos:prefLabel "Team & Coordination Roles"@en .

du:verb_verify a skos:Concept,
        du:ActionVerb ;
