    skos:prefLabel "Regulators / Authorities"@en .

du:U_T34 a skos:Concept,
        du:Mitigation ;
    skos:definition "A mitigation strategy that reduces uncertainty by predefining technologies, documentation, and processes, relying on consolidated, repeatable, and well-understood practices, while confining experimentation to explicitly controlled areas."@en ;
    skos:prefLabel "Controlled standardization"@en ;
    du:level "Type"^^xsd:string .

du:object_decisions-governance a skos:Concept,
        du:Object ;
    skos:prefLabel "Decisions & Governance"@en .

du:verb_standardize a skos:Concept,
        du:ActionVerb ;
    skos:prefLabel "Standardize"@en .

du:U_T36 a skos:Concept,
        du:Mitigation ;
    skos:definition "A mitigation strategy that reduces uncertainty by systematically checking decisions, actors, designs, and outcomes against explicit criteria, evidence, or reference standards, identifying mismatches early and preventing unverified assumptions from propagating across project phases."@en ;
    skos:prefLabel "Verification and validation"@en ;
    du:level "Type"^^xsd:string .

du:object_flexibility-reuse-circularity a skos:Concept,
        du:Object ;
    skos:prefLabel "Flexibility / Reuse / Circularity"@en .

du:object_market-demand a skos:Concept,
        du:Object ;
    skos:prefLabel "Market demand"@en .

du:object_users-demand a skos:Concept,
        du:Object ;
    skos:prefLabel "Users & Demand"@en .

du:U_T01 a skos:Concept,
        du:Uncertainty ;
    skos:definition "Uncertainty arising from unclear or incomplete user requirements."@en ;
    skos:prefLabel "Design requirements uncertainty"@en ;
    du:level "Type"^^xsd:string .

du:U_T04 a skos:Concept,
        du:Uncertainty ;
    skos:definition "Uncertainty arising from incomplete, inaccurate, or inconsistently represented information,  particularly due to the processes and models used to represent reality for design decisions, including assumptions, simplifications, and uncertain input parameters."@en ;
    skos:prefLabel "Information uncertainty"@en ;
    du:level "Type"^^xsd:string .

du:U_T07 a skos:Concept,
        du:Uncertainty ;
    skos:definition "Uncertainty arising from external economic, market, fiscal, geopolitical, and price/availability conditions that affect costs, demand, and project constraints over time."@en ;
    skos:prefLabel "Socio-economic & market uncertainty"@en ;
    du:level "Type"^^xsd:string .

du:U_T29 a skos:Concept,
        du:Mitigation ;
    skos:definition "A mitigation strategy that reduces uncertainty by systematically interpreting empirical, contextual, and comparative evidence, rather than assumptions, to inform decisions about requirements, design solutions, and performance."@en ;
    skos:prefLabel "Evidence-based interpretation"@en ;
    du:level "Type"^^xsd:string .

du:U_T31 a skos:Concept,
        du:Mitigation ;
    skos:definition "A mitigation strategy that reduces uncertainty by explicitly fixing reference points, boundaries, and decision criteri such as requirements, scopes, roles, thresholds, and contractual conditions so that ambiguity does not propagate across project phases."@en ;
    skos:prefLabel "Define ans formalize"@en ;
    du:level "Type"^^xsd:string .

