du:U_T33 a skos:Concept,
        du:Mitigation ;
    skos:definition "A mitigation strategy that reduces uncertainty by anticipating future conditions, transformations, and operational demands during early decision-making, and embedding these expectations into design, technical systems, contracts, and operational strategies so that change, degradation, and evolution can occur without disruptive intervention."@en ;
    skos:prefLabel "Plan ahead"@en ;
    du:level "Type"^^xsd:string .

