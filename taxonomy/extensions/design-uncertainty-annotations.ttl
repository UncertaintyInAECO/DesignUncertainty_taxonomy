du:U_T03 a skos:Concept,
        du:Uncertainty ;
    skos:definition "Uncertainty arising from the iterative and evolving nature of the design process, including coordination between stakeholders and systems,  and changes in decisions."@en ;
    skos:prefLabel "Design process uncertainty"@en ;
    du:level "Type"^^xsd:string .

du:U_T30 a skos:Concept,
        du:Mitigation ;
    skos:definition "A mitigation strategy that reduces uncertainty by aligning actors, roles, and interpretations so that decisions and information remain coherent across project phases."@en ;
    skos:prefLabel "Coordinate"@en ;
    du:level "Type"^^xsd:string .

du:U_T32 a skos:Concept,
        du:Mitigation ;
    skos:definition "A mitigation strategy that reduces uncertainty by constructing explicit representations, often using digital technologies, that make future states, constraints, and consequences visible, explorable, and comparable, without requiring immediate commitment."@en ;
    skos:prefLabel "Represent and simulate"@en ;
    du:level "Type"^^xsd:string .

du:U_T35 a skos:Concept,
        du:Mitigation ;
    skos:definition "A mitigation strategy that reduces uncertainty by systematically recording, updating, and preserving information, decisions, and experience over time, ensuring traceability, continuity, and reuse of knowledge across project phases, actors, and lifecycle stages."@en ;
    skos:prefLabel "Track and preserve information"@en ;
    du:level "Type"^^xsd:string .

