    du:requiresAction du:verb_standardize .

du:U_T67 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T35 ;
    skos:definition "A mitigation instance that reduces uncertainty by capturing, updating, and reusing institutional knowledge, regulatory learning, project experience, and performance records over time to support future decision-making and actor selection."@en ;
