    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_verify .

du:U_T76 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T37 ;
    skos:definition "A mitigation instance that reduces uncertainty by verifying execution quality against detailed technical drawings and approved samples to ensure fidelity between design intent and built outcome."@en ;
    skos:prefLabel "Technical quality control"@en ;
    du:addressesObject_m du:object_design-solution-technical-definition ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_contractors ;
    du:performedInPhase du:phase_construction-execution ;
    du:requiresAction du:verb_verify .

du:U_T77 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T38 ;
    skos:definition "A mitigation instance that reduces uncertainty by verifying maintenance actions for feasibility, durability, and interference with design intent before implementation."@en ;
