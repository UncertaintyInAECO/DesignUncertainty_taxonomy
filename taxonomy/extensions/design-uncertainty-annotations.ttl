    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_plan .

du:U_T63 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T33 ;
    skos:definition "A mitigation instance that reduces uncertainty by proactively identifying future information needs and relevant actors early in the project lifecycle."@en ;
    skos:prefLabel "Proactive Information collection"@en ;
    du:addressesObject_m du:object_information-documentation ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_initiation-feasibility ;
    du:requiresAction du:verb_plan .

du:U_T64 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T33 ;
    skos:definition "A mitigation instance that reduces construction uncertainty by planning sourcing, transport timing, and logistics to stabilize cost and schedule risks."@en ;
    skos:prefLabel "Supply chain planning"@en ;
