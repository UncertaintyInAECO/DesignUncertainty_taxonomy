@prefix du: <https://w3id.org/design-uncertainty/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

du:ActionVerb a rdfs:Class .

du:Mitigation a rdfs:Class .

du:Nature a rdfs:Class .

du:Object a rdfs:Class .

du:Phase a rdfs:Class .

du:Stakeholder a rdfs:Class .

du:Uncertainty a rdfs:Class .

du:IsOfNature a rdf:Property ;
    rdfs:label "is of nature"@en ;
    rdfs:domain du:Uncertainty ;
    rdfs:range du:Nature .

du:U_T05 a skos:Concept,
        du:Uncertainty ;
    skos:definition "Uncertainty about how the building will perform over time in real conditions, including degradation, changing performance expectations, and gaps between predicted and actual performance."@en ;
    skos:prefLabel "Performance uncertainty"@en ;
    du:level "Type"^^xsd:string .

du:U_T08 a skos:Concept,
        du:Uncertainty ;
    skos:definition "Uncertainty about whether and when a project can be delivered as intended due to viability, funding, or dependence on external enabling conditions (e.g., infrastructure capacity and connections)."@en ;
    skos:prefLabel "Project realization & feasibility uncertainty"@en ;
    du:level "Type"^^xsd:string .

du:U_T09 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T06 ;
    skos:definition "Uncertainty about the timing and conditions of permits, including late or changing authority demands."@en ;
    skos:prefLabel "Permitting timeline unpredictability"@en ;
    du:IsOfNature du:nature_epistemic,
        du:nature_strategic ;
    du:addressesObject du:object_regulations ;
    du:emergesInPhase du:phase_initiation-feasibility ;
    du:introducedBy du:stakeholder_regulators-authorities ;
    du:level "Instance"^^xsd:string ;
    du:notes "Most mentioned"@en .

du:U_T10 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T01 ;
    skos:definition "Uncertainty arising when users/clients cannot clearly articulate needs, or from insufficient baseline data about users, demand, and context (e.g., behaviors, needs, projections), reducing confidence in requirement-setting and making the brief incomplete and unstable."@en ;
    skos:prefLabel "Unclear project objective and needs"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_requirements-brief ;
    du:emergesInPhase du:phase_briefing-requirements ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_client-owner ;
    du:level "Instance"^^xsd:string ;
    du:notes "Most mentioned"@en .

du:U_T11 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T01 ;
    skos:definition "Uncertainty arising when client decisions change unpredictably over time, sometimes because of misunderstood approved designs or requirements, leading to late corrections and change requests."@en ;
    skos:prefLabel "Client decision instability"@en ;
    du:IsOfNature du:nature_epistemic,
        du:nature_strategic ;
    du:addressesObject du:object_decisions-governance ;
    du:emergesInPhase du:phase_design ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_client-owner ;
    du:level "Instance"^^xsd:string .

du:U_T12 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T01 ;
    skos:definition "Uncertainty arising when a developer/brand defines requirements on behalf of an unknown or absent end user, and later end-user involvement triggers significant requirement changes."@en ;
    skos:prefLabel "Missrepresented end user"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_requirements-brief ;
    du:emergesInPhase du:phase_briefing-requirements ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_client-owner ;
    du:level "Instance"^^xsd:string .

du:U_T13 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T07 ;
    skos:definition "Uncertainty arising from shifting market conditions (demand, expectations, price volatility, sector trends) that force changes in targets, specifications."@en ;
    skos:prefLabel "Market volatility"@en ;
    du:IsOfNature du:nature_aleatory ;
    du:addressesObject du:object_market-demand ;
    du:emergesInPhase du:phase_initiation-feasibility ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_market-actors ;
    du:level "Instance"^^xsd:string .

du:U_T14 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T03 ;
    skos:definition "Uncertainty arising from the non-repeatable nature of design work, where requirements cannot be deterministically mapped to solutions and must be continuously interpreted and negotiated during the process, especially with the client."@en ;
    skos:prefLabel "Project uniqueness"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_design-solution-technical-definition ;
    du:emergesInPhase du:phase_design ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_designers ;
    du:level "Instance"^^xsd:string .

du:U_T15 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T02 ;
    skos:definition "Uncertainty arising from the inability to predict how building uses, functional requirements, and technologies will evolve over the long operational life of the building, which affects early decisions on systems zoning, service distribution, and maintainability."@en ;
    skos:prefLabel "Uncertain future needs and uses"@en ;
    du:IsOfNature du:nature_aleatory ;
    du:addressesObject du:object_flexibility-reuse-circularity ;
    du:emergesInPhase du:phase_design ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_end-users ;
    du:level "Instance"^^xsd:string .

du:U_T16 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T03 ;
    skos:definition "Uncertainty arising when design leadership, coordination, and multidisciplinary integration are insufficient"@en ;
    skos:prefLabel "Weak design management and design coordination"@en ;
    du:IsOfNature du:nature_strategic ;
    du:addressesObject du:object_team-coordination-roles ;
    du:emergesInPhase du:phase_design ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_designers ;
    du:level "Instance"^^xsd:string ;
    du:notes "Most mentioned"@en .

du:U_T17 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T03 ;
    skos:definition "Uncertainty arising from design outputs that are incomplete, under-specified, or not executable at tender time, which shifts unresolved decisions into execution."@en ;
    skos:prefLabel "Low quality / incomplete design deliverables at tender"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_information-documentation ;
    du:emergesInPhase du:phase_design ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_designers ;
    du:level "Instance"^^xsd:string ;
    du:notes "Most mentioned"@en .

du:U_T18 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T03 ;
    skos:definition "Uncertainty arising from iterative “ping-pong” negotiation between disciplines, requiring compromises between the vision and whether it is technically/contractually feasible."@en ;
    skos:prefLabel "Interactive design process"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_design-solution-technical-definition ;
    du:emergesInPhase du:phase_design ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_designers ;
    du:level "Instance"^^xsd:string .

du:U_T19 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T03 ;
    skos:definition "Uncertainty arising when substantial portions of detailing and executive design are left to contractors (or depend on contractor shop drawings), reducing designer control."@en ;
    skos:prefLabel "Delegation of executive/detail design to contractors"@en ;
    du:IsOfNature du:nature_strategic ;
    du:addressesObject du:object_contracts-procurement ;
    du:emergesInPhase du:phase_tender-contracting ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_client-owner ;
    du:level "Instance"^^xsd:string .

du:U_T20 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T07 ;
    skos:definition "Uncertainty arising from market-driven price volatility and the time gap between estimating, procuring, and installing materials/components, which creates cost revision risk and can trigger scope/budget changes."@en ;
    skos:prefLabel "Price volatility"@en ;
    du:IsOfNature du:nature_aleatory ;
    du:addressesObject du:object_supply-chain-logistics ;
    du:emergesInPhase du:phase_tender-contracting ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_market-actors ;
    du:level "Instance"^^xsd:string ;
    du:notes "including logistics and transport conditions"@en .

du:U_T21 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T07 ;
    skos:definition "Uncertainty arising from unforeseen systemic events, such as pandemics, wars, labor shortages, or contractor suspension, that disrupt markets and institutions, affecting workforce availability, contractor continuity, costs, and schedules."@en ;
    skos:prefLabel "External shocks"@en ;
    du:IsOfNature du:nature_aleatory ;
    du:addressesObject du:object_supply-chain-logistics ;
    du:emergesInPhase du:phase_construction-execution ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_market-actors ;
    du:level "Instance"^^xsd:string .

du:U_T22 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T03 ;
    skos:definition "Uncertainty arising from overlapping design, approval, and construction activities in parallel, where unresolved decisions propagate downstream and amplify changes, claims, and rework."@en ;
    skos:prefLabel "Working in parallel"@en ;
    du:IsOfNature du:nature_strategic ;
    du:addressesObject du:object_contracts-procurement ;
    du:emergesInPhase du:phase_tender-contracting ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_client-owner ;
    du:level "Instance"^^xsd:string .

du:U_T23 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T04 ;
    skos:definition "Uncertainty arising from missing, late, or improperly collected information during construction (e.g., existing conditions, quantities, or as-built data), limiting reliable control over execution."@en ;
    skos:prefLabel "Missing or unreliable site and execution data"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_information-documentation ;
    du:emergesInPhase du:phase_construction-execution ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_contractors ;
    du:level "Instance"^^xsd:string .

du:U_T24 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T07 ;
    skos:definition "Uncertainty arising from variability in workforce availability, experience, and skill levels on site, which affects productivity, quality, and schedule reliability."@en ;
    skos:prefLabel "Workforce availability, skill level, and turnover"@en ;
    du:IsOfNature du:nature_aleatory ;
    du:addressesObject du:object_supply-chain-logistics ;
    du:emergesInPhase du:phase_construction-execution ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_market-actors ;
    du:level "Instance"^^xsd:string ;
    du:notes "Not really design uncertainty"@en .

du:U_T25 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T04 ;
    skos:definition "Uncertainty arising when designers lack sufficient understanding of construction methods, site constraints, and execution realities, leading to design assumptions that prove infeasible or risky during construction."@en ;
    skos:prefLabel "Designers’ limited understanding of construction methods"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_design-solution-technical-definition ;
    du:emergesInPhase du:phase_design ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_designers ;
    du:level "Instance"^^xsd:string .

du:U_T26 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T04 ;
    skos:definition "Uncertainty arising when quantitative models (e.g.  LCA, performance models) rely on input parameters that are unavailable, or highly uncertain. Including the lack of urban-scale information for reliable environmental performance predictions."@en ;
    skos:prefLabel "Insufficient data for quantitative decision-support models"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_tools-models-bim-vr-sim ;
    du:emergesInPhase du:phase_design ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_designers ;
    du:level "Instance"^^xsd:string .

du:U_T27 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T01 ;
    skos:definition "Uncertainty arising when marketing or sales teams commit to features or specifications without prior technical, regulatory, or economic validation, forcing the project team to resolve infeasible or unrealistic promises after contracts are signed."@en ;
    skos:prefLabel "Over-committed sales specifications"@en ;
    du:IsOfNature du:nature_strategic ;
    du:addressesObject du:object_requirements-brief ;
    du:emergesInPhase du:phase_initiation-feasibility ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_client-owner ;
    du:level "Instance"^^xsd:string .

du:U_T28 a skos:Concept,
        du:Uncertainty ;
    skos:broader du:U_T04 ;
    skos:definition "Uncertainty caused by the loss of tacit and explicit knowledge when the design and engineering team leaves after completion, leaving operations and facility management without access to critical project infotmation.  Operations and maintenance rely on outdated, incomplete, or unreliable as-built information, particularly in existing buildings with undocumented modifications over time."@en ;
    skos:prefLabel "Knowledge loss at handover"@en ;
    du:IsOfNature du:nature_epistemic ;
    du:addressesObject du:object_information-documentation ;
    du:emergesInPhase du:phase_use-fm ;
    du:evidenceSource "Interview framework"@en ;
    du:introducedBy du:stakeholder_client-owner ;
    du:level "Instance"^^xsd:string .

du:U_T39 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T29 ;
    skos:definition "A mitigation instance that reduces design uncertainty by analyzing internal technical criteria (performance, cost, materials, aesthetics) during design to balance trade-offs"@en ;
    skos:prefLabel "Trade-off Analysis"@en ;
    du:addressesObject_m du:object_design-solution-technical-definition ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_analyze .

du:U_T40 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T29 ;
    skos:definition "A mitigation instance that reduces uncertainty by relying on critical human judgment to recognize, interpret, and correct issues that automated tools may miss, rather than depending solely on technical systems"@en ;
    skos:prefLabel "Critical human judgement"@en ;
    du:addressesObject_m du:object_tools-models-bim-vr-sim ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_analyze .

du:U_T41 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T30 ;
    skos:definition "A mitigation strategy that reduces uncertainty by structurally integrating design and construction expertise through centralized leadership, early contractor involvement, and unified organizational responsibility."@en ;
    skos:prefLabel "Integrated design coordination"@en ;
    du:addressesObject_m du:object_team-coordination-roles ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_coordinate .

du:U_T42 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T30 ;
    skos:definition "A mitigation strategy that reduces uncertainty by actively coordinating with clients through iterative dialogue, translation of aspirations into measurable parameters, and tailored communication to build a shared and stable brief."@en ;
    skos:prefLabel "Structured Client & Brief Alignment"@en ;
    du:addressesObject_m du:object_requirements-brief ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_briefing-requirements ;
    du:requiresAction du:verb_coordinate .

du:U_T43 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T30 ;
    skos:definition "A mitigation strategy that reduces uncertainty by coordinating multidisciplinary expertise early in feasibility stages to interpret constraints and align technical understanding before design decisions are fixed, including technical coordination between different tools."@en ;
    skos:prefLabel "Multidisciplinary Involvement"@en ;
    du:addressesObject_m du:object_team-coordination-roles ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_initiation-feasibility ;
    du:requiresAction du:verb_coordinate .

du:U_T44 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T30 ;
    skos:definition "A mitigation strategy that reduces uncertainty during execution by formalizing communication channels and coordination roles on site, ensuring structured information flow and decision control."@en ;
    skos:prefLabel "Communication during constrution"@en ;
    du:addressesObject_m du:object_team-coordination-roles ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_contractors ;
    du:performedInPhase du:phase_construction-execution ;
    du:requiresAction du:verb_coordinate .

du:U_T45 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T30 ;
    skos:definition "A mitigation strategy that reduces uncertainty by directly involving users and stakeholders in the requirements phase to surface operational realities and avoid late-stage revisions."@en ;
    skos:prefLabel "User involvement"@en ;
    du:addressesObject_m du:object_users-demand ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_briefing-requirements ;
    du:requiresAction du:verb_coordinate .

du:U_T46 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T30 ;
    skos:definition "A mitigation strategy that reduces uncertainty by formally aligning roles, responsibilities, incentives, and long-term obligations between contractual actors (e.g., developers, designers, contractors, operators)."@en ;
    skos:prefLabel "Contractual & Responsibility Alignment"@en ;
    du:addressesObject_m du:object_contracts-procurement ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_tender-contracting ;
    du:requiresAction du:verb_coordinate .

du:U_T47 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T31 ;
    skos:definition "A mitigation instance that reduces uncertainty by explicitly defining selection criteria, contractual scope, roles, responsibilities, and performance obligations within contracting frameworks."@en ;
    skos:prefLabel "Contractual formalization"@en ;
    du:addressesObject_m du:object_contracts-procurement ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_tender-contracting ;
    du:requiresAction du:verb_define .

du:U_T48 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T31 ;
    skos:definition "A mitigation instance that reduces uncertainty by explicitly structuring requirements during briefing, translating constraints, sustainability criteria, and known parameters into a stable and enforceable design brief."@en ;
    skos:prefLabel "Control through requirement structuring"@en ;
    du:addressesObject_m du:object_requirements-brief ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_briefing-requirements ;
    du:requiresAction du:verb_define .

du:U_T49 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T31 ;
    skos:definition "A mitigation instance that reduces uncertainty by formalizing decision authority, defining acceptable change ranges, and explicitly quantifying uncertainty levels, thereby preventing uncontrolled ambiguity and escalation across project stages."@en ;
    skos:prefLabel "Decision & Change Governance"@en ;
    du:addressesObject_m du:object_decisions-governance ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_define .

du:U_T50 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T31 ;
    skos:definition "Reduces performance uncertainty by using sustainability certifications (e.g. LEED) as market signals that shape expectations, attract tenants, and justify performance-related investments"@en ;
    skos:prefLabel "Set performance expectation"@en ;
    du:addressesObject_m du:object_market-demand ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_define .

du:U_T51 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T32 ;
    skos:definition "A mitigation instance that reduces uncertainty by developing and managing structured digital design models (e.g., BIM), enabling clearer visualization, consistency across repetitive elements, traceability of information responsibility, and greater predictability of the final outcome."@en ;
    skos:prefLabel "The use of BIM for design"@en ;
    du:addressesObject_m du:object_tools-models-bim-vr-sim ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_model .

du:U_T52 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T32 ;
    skos:definition "A mitigation instance that reduces uncertainty by using visual and immersive representations (e.g., renders, VR) to make design intent accessible to clients and non-experts, enabling informed questioning, clarification, and decision-making during briefing."@en ;
    skos:prefLabel "Visualization for non experts (users)"@en ;
    du:addressesObject_m du:object_tools-models-bim-vr-sim ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_briefing-requirements ;
    du:requiresAction du:verb_model .

du:U_T53 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T32 ;
    skos:definition "A mitigation instance that reduces uncertainty during construction by using digital representations and simulations (e.g., point clouds, 4D sequencing, AR/VR site inspection) to anticipate constraints, visualize site conditions, and improve coordination before and during execution."@en ;
    skos:prefLabel "Use Simulation and visualizations in the construction phase"@en ;
    du:addressesObject_m du:object_tools-models-bim-vr-sim ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_contractors ;
    du:performedInPhase du:phase_construction-execution ;
    du:requiresAction du:verb_model .

du:U_T54 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T32 ;
    skos:definition "Mitigates uncertainty by mathematically quantifying the effects of uncertain inputs through probabilistic simulation, producing ranges and confidence intervals rather than single deterministic results"@en ;
    skos:prefLabel "Probabalistic modeling"@en ;
    du:evidenceSource "Interview framework"@en ;
    du:requiresAction du:verb_model .

du:U_T55 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T32 ;
    skos:definition "A mitigation instance that reduces uncertainty by modeling financial viability and return expectations before design commitments are made."@en ;
    skos:prefLabel "Buisness plan"@en ;
    du:addressesObject_m du:object_market-demand ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_initiation-feasibility ;
    du:requiresAction du:verb_model .

du:U_T56 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T32 ;
    skos:definition "Reduces performance uncertainty by using BIM as a long-term digital repository for facility management, enabling accurate, up-to-date knowledge of systems, components, and maintenance needs throughout the building’s operational life"@en ;
    skos:prefLabel "FM BIM"@en ;
    du:addressesObject_m du:object_tools-models-bim-vr-sim ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_facility-managers-operators ;
    du:performedInPhase du:phase_use-fm ;
    du:requiresAction du:verb_model .

du:U_T57 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T33 ;
    skos:definition "A mitigation instance that reduces uncertainty by embedding capacity for transformation, reuse, and evolution directly into spatial, technical, and material systems at the design stage, so that future change can occur without disruptive intervention."@en ;
    skos:prefLabel "Embedded Adaptability"@en ;
    du:addressesObject_m du:object_flexibility-reuse-circularity ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned from all types!"@en ;
