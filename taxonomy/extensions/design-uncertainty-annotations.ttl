    du:performedInPhase du:phase_post-project-organizational ;
    du:requiresAction du:verb_track .

du:U_T68 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T35 ;
    skos:definition "A mitigation instance that reduces uncertainty by progressively collecting, structuring, and validating baseline documentation and contextual knowledge starting from early project phases to avoid informational gaps later."@en ;
    skos:prefLabel "Information documentation"@en ;
    du:addressesObject_m du:object_information-documentation ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_initiation-feasibility ;
    du:requiresAction du:verb_track .

du:U_T69 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T35 ;
    skos:definition "A mitigation instance that reduces uncertainty by systematically recording, tracking, and evaluating reusable furniture and components, enabling informed decisions about reuse, adaptation, or replacement during design and refurbishment"@en ;
    skos:prefLabel "Organizational Asset Tracking for Reuse"@en ;
    du:addressesObject_m du:object_information-documentation ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_use-fm ;
    du:requiresAction du:verb_track .

du:U_T70 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T35 ;
    skos:definition "A mitigation instance that reduces uncertainty by providing standardized, structured lifecycle information (e.g., Digital Product Passports) about materials and components, supporting circular design and end-of-life decision-making."@en ;
    skos:prefLabel "Standardized Lifecycle Information Systems"@en ;
    du:addressesObject_m du:object_information-documentation ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_use-fm ;
    du:requiresAction du:verb_track .

du:U_T71 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T35 ;
    skos:definition "A mitigation instance that reduces uncertainty by maintaining a traceable digital record of design evolution and changes (e.g., via BIM), ensuring continuity and clarity during handovers across actors and phases."@en ;
    skos:prefLabel "Design Traceability via Digital Models"@en ;
    du:addressesObject_m du:object_tools-models-bim-vr-sim ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_track .

du:U_T72 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T35 ;
    skos:definition "A mitigation instance that reduces uncertainty by systematically monitoring and documenting construction progress, approvals, and open issues through structured reporting and supervision mechanisms."@en ;
    skos:prefLabel "Construction Progress Tracking"@en ;
    du:addressesObject_m du:object_information-documentation ;
    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_contractors ;
    du:performedInPhase du:phase_construction-execution ;
    du:requiresAction du:verb_track .

du:U_T73 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T36 ;
    skos:definition "A mitigation instance that reduces uncertainty by verifying the competence, qualifications, and organizational capability of contractors and design teams before engagement or tender award."@en ;
    skos:prefLabel "Partner Qualification"@en ;
