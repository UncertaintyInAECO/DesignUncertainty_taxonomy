du:U_T62 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T33 ;
    skos:definition "A mitigation instance that reduces uncertainty by deliberately selecting appropriate tools and workflows (e.g., CAD vs. BIM) based on project characteristics such as speed and non-standard conditions."@en ;
    skos:prefLabel "Strategic Method & Tool Planning"@en ;
    du:addressesObject_m du:object_tools-models-bim-vr-sim ;
