    du:evidenceSource "Interview framework"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_design ;
    du:requiresAction du:verb_plan .

du:U_T61 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T33 ;
    skos:definition "A mitigation instance that reduces uncertainty by allocating structured time and analytical effort during early programming to clarify scope and optimize decisions before formal commitments."@en ;
    skos:prefLabel "Early planning"@en ;
