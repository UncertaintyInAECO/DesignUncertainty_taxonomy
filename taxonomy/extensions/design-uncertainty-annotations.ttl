du:U_T02 a skos:Concept,
        du:Uncertainty ;
    skos:definition "Uncertainty related to a building’s ability to accommodate future changes or adapt to evolving needs, technologies, or external conditions over time."@en ;
    skos:prefLabel "Flexibility and adaptability uncertainty"@en ;
    du:level "Type"^^xsd:string .

du:U_T06 a skos:Concept,
        du:Uncertainty ;
    skos:definition "Uncertainty arising from statutory requirements, permitting and approvals, interpretation differences, and changes in regulations that constrain design decisions and timelines."@en ;
    skos:prefLabel "Regulatory uncertainty"@en ;
    du:level "Type"^^xsd:string .

du:U_T37 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T29 ;
    skos:definition "A mitigation instance that reduces uncertainty by grounding decisions in detailed analysis of existing physical, historical, environmental, and regulatory conditions, ensuring that design and feasibility judgments are based on verified contextual evidence rather than assumptions."@en ;
    skos:prefLabel "Early stage contextual analysis"@en ;
    du:addressesObject_m du:object_information-documentation ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned"@en ;
    du:performedByStakeholder du:stakeholder_designers ;
    du:performedInPhase du:phase_initiation-feasibility ;
    du:requiresAction du:verb_analyze .

du:U_T38 a skos:Concept,
        du:Mitigation ;
    skos:broader du:U_T29 ;
    skos:definition "A mitigation instance that reduces uncertainty by systematically analyzing observed, measured, or comparable user and market behavior to validate assumptions about requirements, spatial performance, and commercial viability."@en ;
    skos:prefLabel "Market and User Evidence Analysis"@en ;
    du:addressesObject_m du:object_users-demand ;
    du:evidenceSource "Interview framework"@en ;
    du:notes "Most mentioned"@en ;
    du:performedByStakeholder du:stakeholder_client-owner ;
    du:performedInPhase du:phase_briefing-requirements ;
    du:requiresAction du:verb_analyze .

