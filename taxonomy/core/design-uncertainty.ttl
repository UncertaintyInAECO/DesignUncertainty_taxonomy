@prefix schema: <http://schema.org/> .
@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xls2rdf: <https://xls2rdf.sparna.fr/vocabulary#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skosthes: <http://purl.org/iso25964/skos-thes#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix qb: <http://purl.org/linked-data/cube#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix euvoc: <http://publications.europa.eu/ontology/euvoc#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosxl: <http://www.w3.org/2008/05/skos-xl#> .

<https://w3id.org/design-uncertainty> a skos:ConceptScheme;
  dct:title "Uncertainty Taxonomy";
  dct:description "Uncertainty Taxonomy";
  skos:hasTopConcept <https://w3id.org/design-uncertainty/Uncertainty>, <https://w3id.org/design-uncertainty/Mitigation> .

<https://w3id.org/design-uncertainty/Uncertainty> a skos:Concept;
  skos:prefLabel "Uncertainty";
  skos:narrower <https://w3id.org/design-uncertainty/U_T01>, <https://w3id.org/design-uncertainty/U_T02>,
    <https://w3id.org/design-uncertainty/U_T03>, <https://w3id.org/design-uncertainty/U_T04>,
    <https://w3id.org/design-uncertainty/U_T05>, <https://w3id.org/design-uncertainty/U_T06>,
    <https://w3id.org/design-uncertainty/U_T07>, <https://w3id.org/design-uncertainty/U_T08>;
  skos:inScheme <https://w3id.org/design-uncertainty>;
  skos:topConceptOf <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T01> a skos:Concept;
  skos:prefLabel "Design requirements uncertainty";
  skos:definition "Uncertainty arising from unclear or incomplete user requirements.";
  skos:broader <https://w3id.org/design-uncertainty/Uncertainty>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T10>, <https://w3id.org/design-uncertainty/U_T11>,
    <https://w3id.org/design-uncertainty/U_T12>, <https://w3id.org/design-uncertainty/U_T27>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T02> a skos:Concept;
  skos:prefLabel "Flexibility and adaptability uncertainty";
  skos:definition "Uncertainty related to a building’s ability to accommodate future changes or adapt to evolving needs, technologies, or external conditions over time.";
  skos:broader <https://w3id.org/design-uncertainty/Uncertainty>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T15>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T03> a skos:Concept;
  skos:prefLabel "Design process uncertainty";
  skos:definition "Uncertainty arising from the iterative and evolving nature of the design process, including coordination between stakeholders and systems, and changes in decisions.";
  skos:broader <https://w3id.org/design-uncertainty/Uncertainty>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T14>, <https://w3id.org/design-uncertainty/U_T16>,
    <https://w3id.org/design-uncertainty/U_T17>, <https://w3id.org/design-uncertainty/U_T18>,
    <https://w3id.org/design-uncertainty/U_T19>, <https://w3id.org/design-uncertainty/U_T22>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T04> a skos:Concept;
  skos:prefLabel "Information uncertainty";
  skos:definition "Uncertainty arising from incomplete, inaccurate, or inconsistently represented information, particularly due to the processes and models used to represent reality for design decisions, including assumptions, simplifications, and uncertain input parameters.";
  skos:broader <https://w3id.org/design-uncertainty/Uncertainty>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T23>, <https://w3id.org/design-uncertainty/U_T25>,
    <https://w3id.org/design-uncertainty/U_T26>, <https://w3id.org/design-uncertainty/U_T28>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T05> a skos:Concept;
  skos:prefLabel "Performance uncertainty";
  skos:definition "Uncertainty about how the building will perform over time in real conditions, including degradation, changing performance expectations, and gaps between predicted and actual performance.";
  skos:broader <https://w3id.org/design-uncertainty/Uncertainty>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T06> a skos:Concept;
  skos:prefLabel "Regulatory uncertainty";
  skos:definition "Uncertainty arising from statutory requirements, permitting and approvals, interpretation differences, and changes in regulations that constrain design decisions and timelines.";
  skos:broader <https://w3id.org/design-uncertainty/Uncertainty>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T09>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T07> a skos:Concept;
  skos:prefLabel "Socio-economic & market uncertainty";
  skos:definition "Uncertainty arising from external economic, market, fiscal, geopolitical, and price/availability conditions that affect costs, demand, and project constraints over time.";
  skos:broader <https://w3id.org/design-uncertainty/Uncertainty>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T13>, <https://w3id.org/design-uncertainty/U_T20>,
    <https://w3id.org/design-uncertainty/U_T21>, <https://w3id.org/design-uncertainty/U_T24>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T08> a skos:Concept;
  skos:prefLabel "Project realization & feasibility uncertainty";
  skos:definition "Uncertainty about whether and when a project can be delivered as intended due to viability, funding, or dependence on external enabling conditions (e.g., infrastructure capacity and connections).";
  skos:broader <https://w3id.org/design-uncertainty/Uncertainty>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T09> a skos:Concept;
  skos:prefLabel "Permitting timeline unpredictability";
  skos:definition "Uncertainty about the timing and conditions of permits, including late or changing authority demands.";
  skos:broader <https://w3id.org/design-uncertainty/U_T06>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T10> a skos:Concept;
  skos:prefLabel "Unclear project objective and needs";
  skos:definition "Uncertainty arising when users/clients cannot clearly articulate needs, or from insufficient baseline data about users, demand, and context (e.g., behaviors, needs, projections), reducing confidence in requirement-setting and making the brief incomplete and unstable.";
  skos:broader <https://w3id.org/design-uncertainty/U_T01>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T11> a skos:Concept;
  skos:prefLabel "Client decision instability";
  skos:definition "Uncertainty arising when client decisions change unpredictably over time, sometimes because of misunderstood approved designs or requirements, leading to late corrections and change requests.";
  skos:broader <https://w3id.org/design-uncertainty/U_T01>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T12> a skos:Concept;
  skos:prefLabel "Missrepresented end user";
  skos:definition "Uncertainty arising when a developer/brand defines requirements on behalf of an unknown or absent end user, and later end-user involvement triggers significant requirement changes.";
  skos:broader <https://w3id.org/design-uncertainty/U_T01>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T13> a skos:Concept;
  skos:prefLabel "Market volatility";
  skos:definition "Uncertainty arising from shifting market conditions (demand, expectations, price volatility, sector trends) that force changes in targets, specifications.";
  skos:broader <https://w3id.org/design-uncertainty/U_T07>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T14> a skos:Concept;
  skos:prefLabel "Project uniqueness";
  skos:definition "Uncertainty arising from the non-repeatable nature of design work, where requirements cannot be deterministically mapped to solutions and must be continuously interpreted and negotiated during the process, especially with the client.";
  skos:broader <https://w3id.org/design-uncertainty/U_T03>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T15> a skos:Concept;
  skos:prefLabel "Uncertain future needs and uses";
  skos:definition "Uncertainty arising from the inability to predict how building uses, functional requirements, and technologies will evolve over the long operational life of the building, which affects early decisions on systems zoning, service distribution, and maintainability.";
  skos:broader <https://w3id.org/design-uncertainty/U_T02>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T16> a skos:Concept;
  skos:prefLabel "Weak design management and design coordination";
  skos:definition "Uncertainty arising when design leadership, coordination, and multidisciplinary integration are insufficient";
  skos:broader <https://w3id.org/design-uncertainty/U_T03>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T17> a skos:Concept;
  skos:prefLabel "Low quality / incomplete design deliverables at tender";
  skos:definition "Uncertainty arising from design outputs that are incomplete, under-specified, or not executable at tender time, which shifts unresolved decisions into execution.";
  skos:broader <https://w3id.org/design-uncertainty/U_T03>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T18> a skos:Concept;
  skos:prefLabel "Interactive design process";
  skos:definition "Uncertainty arising from iterative “ping-pong” negotiation between disciplines, requiring compromises between the vision and whether it is technically/contractually feasible.";
  skos:broader <https://w3id.org/design-uncertainty/U_T03>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T19> a skos:Concept;
  skos:prefLabel "Delegation of executive/detail design to contractors";
  skos:definition "Uncertainty arising when substantial portions of detailing and executive design are left to contractors (or depend on contractor shop drawings), reducing designer control.";
  skos:broader <https://w3id.org/design-uncertainty/U_T03>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T20> a skos:Concept;
  skos:prefLabel "Price volatility";
  skos:definition "Uncertainty arising from market-driven price volatility and the time gap between estimating, procuring, and installing materials/components, which creates cost revision risk and can trigger scope/budget changes.";
  skos:broader <https://w3id.org/design-uncertainty/U_T07>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T21> a skos:Concept;
  skos:prefLabel "External shocks";
  skos:definition "Uncertainty arising from unforeseen systemic events, such as pandemics, wars, labor shortages, or contractor suspension, that disrupt markets and institutions, affecting workforce availability, contractor continuity, costs, and schedules.";
  skos:broader <https://w3id.org/design-uncertainty/U_T07>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T22> a skos:Concept;
  skos:prefLabel "Working in parallel";
  skos:definition "Uncertainty arising from overlapping design, approval, and construction activities in parallel, where unresolved decisions propagate downstream and amplify changes, claims, and rework.";
  skos:broader <https://w3id.org/design-uncertainty/U_T03>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T23> a skos:Concept;
  skos:prefLabel "Missing or unreliable site and execution data";
  skos:definition "Uncertainty arising from missing, late, or improperly collected information during construction (e.g., existing conditions, quantities, or as-built data), limiting reliable control over execution.";
  skos:broader <https://w3id.org/design-uncertainty/U_T04>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T24> a skos:Concept;
  skos:prefLabel "Workforce availability, skill level, and turnover";
  skos:definition "Uncertainty arising from variability in workforce availability, experience, and skill levels on site, which affects productivity, quality, and schedule reliability.";
  skos:broader <https://w3id.org/design-uncertainty/U_T07>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T25> a skos:Concept;
  skos:prefLabel "Designers’ limited understanding of construction methods";
  skos:definition "Uncertainty arising when designers lack sufficient understanding of construction methods, site constraints, and execution realities, leading to design assumptions that prove infeasible or risky during construction.";
  skos:broader <https://w3id.org/design-uncertainty/U_T04>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T26> a skos:Concept;
  skos:prefLabel "Insufficient data for quantitative decision-support models";
  skos:definition "Uncertainty arising when quantitative models (e.g. LCA, performance models) rely on input parameters that are unavailable, or highly uncertain. Including the lack of urban-scale information for reliable environmental performance predictions.";
  skos:broader <https://w3id.org/design-uncertainty/U_T04>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T27> a skos:Concept;
  skos:prefLabel "Over-committed sales specifications";
  skos:definition "Uncertainty arising when marketing or sales teams commit to features or specifications without prior technical, regulatory, or economic validation, forcing the project team to resolve infeasible or unrealistic promises after contracts are signed.";
  skos:broader <https://w3id.org/design-uncertainty/U_T01>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T28> a skos:Concept;
  skos:prefLabel "Knowledge loss at handover";
  skos:definition "Uncertainty caused by the loss of tacit and explicit knowledge when the design and engineering team leaves after completion, leaving operations and facility management without access to critical project infotmation. Operations and maintenance rely on outdated, incomplete, or unreliable as-built information, particularly in existing buildings with undocumented modifications over time.";
  skos:broader <https://w3id.org/design-uncertainty/U_T04>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/Mitigation> a skos:Concept;
  skos:prefLabel "Mitigation strategy";
  skos:narrower <https://w3id.org/design-uncertainty/U_T29>, <https://w3id.org/design-uncertainty/U_T30>,
    <https://w3id.org/design-uncertainty/U_T31>, <https://w3id.org/design-uncertainty/U_T32>,
    <https://w3id.org/design-uncertainty/U_T33>, <https://w3id.org/design-uncertainty/U_T34>,
    <https://w3id.org/design-uncertainty/U_T35>, <https://w3id.org/design-uncertainty/U_T36>;
  skos:inScheme <https://w3id.org/design-uncertainty>;
  skos:topConceptOf <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T29> a skos:Concept;
  skos:prefLabel "Evidence-based interpretation";
  skos:definition "A mitigation strategy that reduces uncertainty by systematically interpreting empirical, contextual, and comparative evidence, rather than assumptions, to inform decisions about requirements, design solutions, and performance.";
  skos:broader <https://w3id.org/design-uncertainty/Mitigation>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T37>, <https://w3id.org/design-uncertainty/U_T38>,
    <https://w3id.org/design-uncertainty/U_T39>, <https://w3id.org/design-uncertainty/U_T40>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T30> a skos:Concept;
  skos:prefLabel "Coordinate";
  skos:definition "A mitigation strategy that reduces uncertainty by aligning actors, roles, and interpretations so that decisions and information remain coherent across project phases.";
  skos:broader <https://w3id.org/design-uncertainty/Mitigation>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T41>, <https://w3id.org/design-uncertainty/U_T42>,
    <https://w3id.org/design-uncertainty/U_T43>, <https://w3id.org/design-uncertainty/U_T44>,
    <https://w3id.org/design-uncertainty/U_T45>, <https://w3id.org/design-uncertainty/U_T46>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T31> a skos:Concept;
  skos:prefLabel "Define ans formalize";
  skos:definition "A mitigation strategy that reduces uncertainty by explicitly fixing reference points, boundaries, and decision criteri such as requirements, scopes, roles, thresholds, and contractual conditions so that ambiguity does not propagate across project phases.";
  skos:broader <https://w3id.org/design-uncertainty/Mitigation>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T47>, <https://w3id.org/design-uncertainty/U_T48>,
    <https://w3id.org/design-uncertainty/U_T49>, <https://w3id.org/design-uncertainty/U_T50>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T32> a skos:Concept;
  skos:prefLabel "Represent and simulate";
  skos:definition "A mitigation strategy that reduces uncertainty by constructing explicit representations, often using digital technologies, that make future states, constraints, and consequences visible, explorable, and comparable, without requiring immediate commitment.";
  skos:broader <https://w3id.org/design-uncertainty/Mitigation>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T51>, <https://w3id.org/design-uncertainty/U_T52>,
    <https://w3id.org/design-uncertainty/U_T53>, <https://w3id.org/design-uncertainty/U_T54>,
    <https://w3id.org/design-uncertainty/U_T55>, <https://w3id.org/design-uncertainty/U_T56>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T33> a skos:Concept;
  skos:prefLabel "Plan ahead";
  skos:definition "A mitigation strategy that reduces uncertainty by anticipating future conditions, transformations, and operational demands during early decision-making, and embedding these expectations into design, technical systems, contracts, and operational strategies so that change, degradation, and evolution can occur without disruptive intervention.";
  skos:broader <https://w3id.org/design-uncertainty/Mitigation>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T57>, <https://w3id.org/design-uncertainty/U_T58>,
    <https://w3id.org/design-uncertainty/U_T59>, <https://w3id.org/design-uncertainty/U_T60>,
    <https://w3id.org/design-uncertainty/U_T61>, <https://w3id.org/design-uncertainty/U_T62>,
    <https://w3id.org/design-uncertainty/U_T63>, <https://w3id.org/design-uncertainty/U_T64>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T34> a skos:Concept;
  skos:prefLabel "Controlled standardization";
  skos:definition "A mitigation strategy that reduces uncertainty by predefining technologies, documentation, and processes, relying on consolidated, repeatable, and well-understood practices, while confining experimentation to explicitly controlled areas.";
  skos:broader <https://w3id.org/design-uncertainty/Mitigation>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T65>, <https://w3id.org/design-uncertainty/U_T66>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T35> a skos:Concept;
  skos:prefLabel "Track and preserve information";
  skos:definition "A mitigation strategy that reduces uncertainty by systematically recording, updating, and preserving information, decisions, and experience over time, ensuring traceability, continuity, and reuse of knowledge across project phases, actors, and lifecycle stages.";
  skos:broader <https://w3id.org/design-uncertainty/Mitigation>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T67>, <https://w3id.org/design-uncertainty/U_T68>,
    <https://w3id.org/design-uncertainty/U_T69>, <https://w3id.org/design-uncertainty/U_T70>,
    <https://w3id.org/design-uncertainty/U_T71>, <https://w3id.org/design-uncertainty/U_T72>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T36> a skos:Concept;
  skos:prefLabel "Verification and validation";
  skos:definition "A mitigation strategy that reduces uncertainty by systematically checking decisions, actors, designs, and outcomes against explicit criteria, evidence, or reference standards, identifying mismatches early and preventing unverified assumptions from propagating across project phases.";
  skos:broader <https://w3id.org/design-uncertainty/Mitigation>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T73>, <https://w3id.org/design-uncertainty/U_T74>,
    <https://w3id.org/design-uncertainty/U_T75>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T37> a skos:Concept;
  skos:prefLabel "Early stage contextual analysis";
  skos:definition "A mitigation instance that reduces uncertainty by grounding decisions in detailed analysis of existing physical, historical, environmental, and regulatory conditions, ensuring that design and feasibility judgments are based on verified contextual evidence rather than assumptions.";
  skos:broader <https://w3id.org/design-uncertainty/U_T29>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T76>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T38> a skos:Concept;
  skos:prefLabel "Market and User Evidence Analysis";
  skos:definition "A mitigation instance that reduces uncertainty by systematically analyzing observed, measured, or comparable user and market behavior to validate assumptions about requirements, spatial performance, and commercial viability.";
  skos:broader <https://w3id.org/design-uncertainty/U_T29>;
  skos:narrower <https://w3id.org/design-uncertainty/U_T77>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T39> a skos:Concept;
  skos:prefLabel "Trade-off Analysis";
  skos:definition "A mitigation instance that reduces design uncertainty by analyzing internal technical criteria (performance, cost, materials, aesthetics) during design to balance trade-offs";
  skos:broader <https://w3id.org/design-uncertainty/U_T29>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T40> a skos:Concept;
  skos:prefLabel "Critical human judgement";
  skos:definition "A mitigation instance that reduces uncertainty by relying on critical human judgment to recognize, interpret, and correct issues that automated tools may miss, rather than depending solely on technical systems";
  skos:broader <https://w3id.org/design-uncertainty/U_T29>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T41> a skos:Concept;
  skos:prefLabel "Integrated design coordination";
  skos:definition "A mitigation strategy that reduces uncertainty by structurally integrating design and construction expertise through centralized leadership, early contractor involvement, and unified organizational responsibility.";
  skos:broader <https://w3id.org/design-uncertainty/U_T30>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T42> a skos:Concept;
  skos:prefLabel "Structured Client & Brief Alignment";
  skos:definition "A mitigation strategy that reduces uncertainty by actively coordinating with clients through iterative dialogue, translation of aspirations into measurable parameters, and tailored communication to build a shared and stable brief.";
  skos:broader <https://w3id.org/design-uncertainty/U_T30>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T43> a skos:Concept;
  skos:prefLabel "Multidisciplinary Involvement";
  skos:definition "A mitigation strategy that reduces uncertainty by coordinating multidisciplinary expertise early in feasibility stages to interpret constraints and align technical understanding before design decisions are fixed, including technical coordination between different tools.";
  skos:broader <https://w3id.org/design-uncertainty/U_T30>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T44> a skos:Concept;
  skos:prefLabel "Communication during constrution";
  skos:definition "A mitigation strategy that reduces uncertainty during execution by formalizing communication channels and coordination roles on site, ensuring structured information flow and decision control.";
  skos:broader <https://w3id.org/design-uncertainty/U_T30>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T45> a skos:Concept;
  skos:prefLabel "User involvement";
  skos:definition "A mitigation strategy that reduces uncertainty by directly involving users and stakeholders in the requirements phase to surface operational realities and avoid late-stage revisions.";
  skos:broader <https://w3id.org/design-uncertainty/U_T30>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T46> a skos:Concept;
  skos:prefLabel "Contractual & Responsibility Alignment";
  skos:definition "A mitigation strategy that reduces uncertainty by formally aligning roles, responsibilities, incentives, and long-term obligations between contractual actors (e.g., developers, designers, contractors, operators).";
  skos:broader <https://w3id.org/design-uncertainty/U_T30>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T47> a skos:Concept;
  skos:prefLabel "Contractual formalization";
  skos:definition "A mitigation instance that reduces uncertainty by explicitly defining selection criteria, contractual scope, roles, responsibilities, and performance obligations within contracting frameworks.";
  skos:broader <https://w3id.org/design-uncertainty/U_T31>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T48> a skos:Concept;
  skos:prefLabel "Control through requirement structuring";
  skos:definition "A mitigation instance that reduces uncertainty by explicitly structuring requirements during briefing, translating constraints, sustainability criteria, and known parameters into a stable and enforceable design brief.";
  skos:broader <https://w3id.org/design-uncertainty/U_T31>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T49> a skos:Concept;
  skos:prefLabel "Decision & Change Governance";
  skos:definition "A mitigation instance that reduces uncertainty by formalizing decision authority, defining acceptable change ranges, and explicitly quantifying uncertainty levels, thereby preventing uncontrolled ambiguity and escalation across project stages.";
  skos:broader <https://w3id.org/design-uncertainty/U_T31>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T50> a skos:Concept;
  skos:prefLabel "Set performance expectation";
  skos:definition "Reduces performance uncertainty by using sustainability certifications (e.g. LEED) as market signals that shape expectations, attract tenants, and justify performance-related investments";
  skos:broader <https://w3id.org/design-uncertainty/U_T31>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T51> a skos:Concept;
  skos:prefLabel "The use of BIM for design";
  skos:definition "A mitigation instance that reduces uncertainty by developing and managing structured digital design models (e.g., BIM), enabling clearer visualization, consistency across repetitive elements, traceability of information responsibility, and greater predictability of the final outcome.";
  skos:broader <https://w3id.org/design-uncertainty/U_T32>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T52> a skos:Concept;
  skos:prefLabel "Visualization for non experts (users)";
  skos:definition "A mitigation instance that reduces uncertainty by using visual and immersive representations (e.g., renders, VR) to make design intent accessible to clients and non-experts, enabling informed questioning, clarification, and decision-making during briefing.";
  skos:broader <https://w3id.org/design-uncertainty/U_T32>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T53> a skos:Concept;
  skos:prefLabel "Use Simulation and visualizations in the construction phase";
  skos:definition "A mitigation instance that reduces uncertainty during construction by using digital representations and simulations (e.g., point clouds, 4D sequencing, AR/VR site inspection) to anticipate constraints, visualize site conditions, and improve coordination before and during execution.";
  skos:broader <https://w3id.org/design-uncertainty/U_T32>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T54> a skos:Concept;
  skos:prefLabel "Probabalistic modeling";
  skos:definition "Mitigates uncertainty by mathematically quantifying the effects of uncertain inputs through probabilistic simulation, producing ranges and confidence intervals rather than single deterministic results";
  skos:broader <https://w3id.org/design-uncertainty/U_T32>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T55> a skos:Concept;
  skos:prefLabel "Buisness plan";
  skos:definition "A mitigation instance that reduces uncertainty by modeling financial viability and return expectations before design commitments are made.";
  skos:broader <https://w3id.org/design-uncertainty/U_T32>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T56> a skos:Concept;
  skos:prefLabel "FM BIM";
  skos:definition "Reduces performance uncertainty by using BIM as a long-term digital repository for facility management, enabling accurate, up-to-date knowledge of systems, components, and maintenance needs throughout the building’s operational life";
  skos:broader <https://w3id.org/design-uncertainty/U_T32>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T57> a skos:Concept;
  skos:prefLabel "Embedded Adaptability";
  skos:definition "A mitigation instance that reduces uncertainty by embedding capacity for transformation, reuse, and evolution directly into spatial, technical, and material systems at the design stage, so that future change can occur without disruptive intervention.";
  skos:broader <https://w3id.org/design-uncertainty/U_T33>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T58> a skos:Concept;
  skos:prefLabel "Lifecycle & Maintenance Anticipation";
  skos:definition "A mitigation instance that reduces performance uncertainty by anticipating degradation, operational demands, failure risk, and lifecycle impacts, embedding maintenance logic, energy strategy, and durability considerations into long-term planning.";
  skos:broader <https://w3id.org/design-uncertainty/U_T33>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T59> a skos:Concept;
  skos:prefLabel "Enable adaptation";
  skos:definition "A mitigation instance that reduces adaptability uncertainty during the use phase by enabling reversible reconfiguration, refurbishment, and layout changes without structural intervention.";
  skos:broader <https://w3id.org/design-uncertainty/U_T33>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T60> a skos:Concept;
  skos:prefLabel "Technical Exhaustivenes";
  skos:definition "A mitigation instance that reduces uncertainty by detailed technical resolution, ensuring robustness, and completeness of design solutions.";
  skos:broader <https://w3id.org/design-uncertainty/U_T33>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T61> a skos:Concept;
  skos:prefLabel "Early planning";
  skos:definition "A mitigation instance that reduces uncertainty by allocating structured time and analytical effort during early programming to clarify scope and optimize decisions before formal commitments.";
  skos:broader <https://w3id.org/design-uncertainty/U_T33>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T62> a skos:Concept;
  skos:prefLabel "Strategic Method & Tool Planning";
  skos:definition "A mitigation instance that reduces uncertainty by deliberately selecting appropriate tools and workflows (e.g., CAD vs. BIM) based on project characteristics such as speed and non-standard conditions.";
  skos:broader <https://w3id.org/design-uncertainty/U_T33>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T63> a skos:Concept;
  skos:prefLabel "Proactive Information collection";
  skos:definition "A mitigation instance that reduces uncertainty by proactively identifying future information needs and relevant actors early in the project lifecycle.";
  skos:broader <https://w3id.org/design-uncertainty/U_T33>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T64> a skos:Concept;
  skos:prefLabel "Supply chain planning";
  skos:definition "A mitigation instance that reduces construction uncertainty by planning sourcing, transport timing, and logistics to stabilize cost and schedule risks.";
  skos:broader <https://w3id.org/design-uncertainty/U_T33>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T65> a skos:Concept;
  skos:prefLabel "Relying on well established methods";
  skos:definition "A mitigation instance that reduces uncertainty by limiting experimentation in technical and constructive choices, relying on consolidated solutions and selectively allowing innovation only within controlled boundaries.";
  skos:broader <https://w3id.org/design-uncertainty/U_T34>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T66> a skos:Concept;
  skos:prefLabel "Process Standardization";
  skos:definition "A mitigation instance that reduces uncertainty by structuring documentation, workflows, and organizational processes into replicable, predictable, and transparent frameworks that guide project development over time.";
  skos:broader <https://w3id.org/design-uncertainty/U_T34>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T67> a skos:Concept;
  skos:prefLabel "Keep Organizational Knowledge";
  skos:definition "A mitigation instance that reduces uncertainty by capturing, updating, and reusing institutional knowledge, regulatory learning, project experience, and performance records over time to support future decision-making and actor selection.";
  skos:broader <https://w3id.org/design-uncertainty/U_T35>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T68> a skos:Concept;
  skos:prefLabel "Information documentation";
  skos:definition "A mitigation instance that reduces uncertainty by progressively collecting, structuring, and validating baseline documentation and contextual knowledge starting from early project phases to avoid informational gaps later.";
  skos:broader <https://w3id.org/design-uncertainty/U_T35>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T69> a skos:Concept;
  skos:prefLabel "Organizational Asset Tracking for Reuse";
  skos:definition "A mitigation instance that reduces uncertainty by systematically recording, tracking, and evaluating reusable furniture and components, enabling informed decisions about reuse, adaptation, or replacement during design and refurbishment";
  skos:broader <https://w3id.org/design-uncertainty/U_T35>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T70> a skos:Concept;
  skos:prefLabel "Standardized Lifecycle Information Systems";
  skos:definition "A mitigation instance that reduces uncertainty by providing standardized, structured lifecycle information (e.g., Digital Product Passports) about materials and components, supporting circular design and end-of-life decision-making.";
  skos:broader <https://w3id.org/design-uncertainty/U_T35>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T71> a skos:Concept;
  skos:prefLabel "Design Traceability via Digital Models";
  skos:definition "A mitigation instance that reduces uncertainty by maintaining a traceable digital record of design evolution and changes (e.g., via BIM), ensuring continuity and clarity during handovers across actors and phases.";
  skos:broader <https://w3id.org/design-uncertainty/U_T35>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T72> a skos:Concept;
  skos:prefLabel "Construction Progress Tracking";
  skos:definition "A mitigation instance that reduces uncertainty by systematically monitoring and documenting construction progress, approvals, and open issues through structured reporting and supervision mechanisms.";
  skos:broader <https://w3id.org/design-uncertainty/U_T35>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T73> a skos:Concept;
  skos:prefLabel "Partner Qualification";
  skos:definition "A mitigation instance that reduces uncertainty by verifying the competence, qualifications, and organizational capability of contractors and design teams before engagement or tender award.";
  skos:broader <https://w3id.org/design-uncertainty/U_T36>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T74> a skos:Concept;
  skos:prefLabel "Compliance Checking";
  skos:definition "A mitigation instance that reduces uncertainty by systematically verifying that design outputs comply with agreed requirements, specifications, and regulatory frameworks before tendering or execution, preventing deviations and late compliance-related surprises.";
  skos:broader <https://w3id.org/design-uncertainty/U_T36>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T75> a skos:Concept;
  skos:prefLabel "Performance-in-Use Validation";
  skos:definition "A mitigation instance that reduces uncertainty by verifying actual spatial or operational performance in use and adjusting assumptions or requirements accordingly.";
  skos:broader <https://w3id.org/design-uncertainty/U_T36>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T76> a skos:Concept;
  skos:prefLabel "Technical quality control";
  skos:definition "A mitigation instance that reduces uncertainty by verifying execution quality against detailed technical drawings and approved samples to ensure fidelity between design intent and built outcome.";
  skos:broader <https://w3id.org/design-uncertainty/U_T37>;
  skos:inScheme <https://w3id.org/design-uncertainty> .

<https://w3id.org/design-uncertainty/U_T77> a skos:Concept;
  skos:prefLabel "Maintenance plan";
  skos:definition "A mitigation instance that reduces uncertainty by verifying maintenance actions for feasibility, durability, and interference with design intent before implementation.";
  skos:broader <https://w3id.org/design-uncertainty/U_T38>;
  skos:inScheme <https://w3id.org/design-uncertainty> .
